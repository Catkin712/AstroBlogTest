---
import Navigation from "../components/Navigation.astro";
import Menu from "../components/Menu.astro";
import ThemeIcon from "../components/ThemeIcon.astro";
---

<header class="site-sidebar">
    <div class="sidebar-inner">
        <div class="sidebar-tools">
            <Menu />
            <ThemeIcon />
        </div>

        <div class="sidebar-search" role="search">
            <label for="site-search">搜索文章</label>
            <input
                id="site-search"
                type="search"
                autocomplete="off"
                placeholder="标题 / 标签 / 作者"
            />
            <div id="search-results" class="search-results" hidden></div>
        </div>

        <a class="profile" href="/" aria-label="Catkin 的首页">
            <img src="/avatar.png" alt="Catkin 的头像" width="96" height="96" />
            <span class="profile-name">Catkin</span>
            <span class="profile-signature">以渺小启程</span>
        </a>

        <nav aria-label="主导航">
            <Navigation />
        </nav>
    </div>
</header>

<style>
    .site-sidebar {
        border-right: 1px solid var(--line-color);
        background: var(--sidebar-bg);
    }

    .sidebar-inner {
        position: sticky;
        top: 0;
        display: flex;
        min-height: 100vh;
        flex-direction: column;
        gap: 1.5rem;
        padding: 2rem 1.25rem;
    }

    .sidebar-tools {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .profile {
        display: grid;
        justify-items: center;
        gap: 0.55rem;
        color: inherit;
        text-align: center;
        text-decoration: none;
    }

    .sidebar-search {
        position: relative;
        display: grid;
        gap: 0.4rem;
    }

    .sidebar-search label {
        color: var(--muted-color);
        font-size: 0.8rem;
        font-weight: 700;
    }

    .sidebar-search input {
        width: 100%;
        border: 1px solid var(--line-color);
        border-radius: 8px;
        background: var(--panel-bg);
        color: var(--text-color);
        padding: 0.6rem 0.7rem;
        font: inherit;
    }

    .sidebar-search input:focus {
        border-color: var(--accent-color);
        outline: 2px solid transparent;
    }

    .search-results {
        display: grid;
        gap: 0.4rem;
        border: 1px solid var(--line-color);
        border-radius: 8px;
        background: var(--panel-bg);
        padding: 0.45rem;
        box-shadow: 0 10px 26px rgb(15 23 42 / 12%);
    }

    .search-results[hidden] {
        display: none;
    }

    :global(.search-result) {
        display: grid;
        gap: 0.15rem;
        border-radius: 6px;
        padding: 0.45rem;
        color: inherit;
        text-decoration: none;
    }

    :global(.search-result:hover),
    :global(.search-result:focus) {
        background: var(--page-bg);
        color: var(--accent-color);
    }

    :global(.search-result span) {
        font-size: 0.9rem;
        font-weight: 700;
    }

    :global(.search-result small),
    :global(.search-empty) {
        color: var(--muted-color);
        font-size: 0.78rem;
    }

    :global(.search-empty) {
        margin: 0;
        padding: 0.45rem;
    }

    .profile img {
        width: 96px;
        height: 96px;
        border: 3px solid var(--panel-bg);
        border-radius: 50%;
        box-shadow: 0 10px 26px rgb(15 23 42 / 14%);
        object-fit: cover;
    }

    .profile-name {
        font-size: 1.25rem;
        font-weight: 800;
    }

    .profile-signature {
        color: var(--muted-color);
        font-size: 0.95rem;
    }

    @media screen and (max-width: 760px) {
        .site-sidebar {
            border-right: 0;
            border-bottom: 1px solid var(--line-color);
        }

        .sidebar-inner {
            position: static;
            min-height: auto;
            gap: 1rem;
            padding: 1rem;
        }

        .sidebar-search {
            order: 3;
        }

        .profile {
            order: 2;
            grid-template-columns: auto 1fr;
            justify-items: start;
            column-gap: 0.75rem;
            text-align: left;
        }

        .profile img {
            grid-row: span 2;
            width: 56px;
            height: 56px;
        }

        .profile-name {
            align-self: end;
            font-size: 1.1rem;
        }

        .profile-signature {
            align-self: start;
        }
    }
</style>
